{
  "sources": {
    "default": "csprng",
    "anu": {
      "api_key": "replace-me-if-you-use-anu"
    },
    "outshift": {
      "api_key": "replace-me-if-you-use-outshift"
    }
  },
  "defaults": {
    "resonance": {
      "provider": "local",
      "model": "nomic-embed-text"
    }
  },
  "tarot": {
    "card_text": {
      "profiles": {
        "descriptive": {
          "template": "Tarot card: {name}. Arcana: {arcana}. Suit: {suit}. Keywords: {keywords}.",
          "overrides": {
            "Death": "Tarot card: Death. Transformation, ending, and renewal."
          }
        }
      }
    }
  }
}
